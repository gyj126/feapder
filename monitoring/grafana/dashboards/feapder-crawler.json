      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "SELECT sum(\"_count\") FROM \"$measurement\" WHERE \"_classify\"='document' AND \"_key\"=~/:download_total$/ AND \"project\"=~/^$project$/ AND \"spider\"=~/^$spider$/ AND $timeFilter GROUP BY time($__interval) fill(0)",
