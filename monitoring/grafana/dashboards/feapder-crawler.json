      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "SELECT count(\"_value\") FROM \"$measurement\" WHERE \"_classify\"='runtime' AND \"_key\"='heartbeat' AND \"project\"=~/^$project$/ AND \"spider\"=~/^$spider$/ AND \"hostname\"=~/^$host$/ AND time > now() - 60s GROUP BY \"spider\", \"hostname\", \"pid\"",
          "rawQuery": true,
