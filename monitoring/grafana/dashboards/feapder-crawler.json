      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"${measurement}\")\n  |> filter(fn: (r) => r[\"_classify\"] == \"document\")\n  |> filter(fn: (r) => r[\"_field\"] == \"_count\")\n  |> filter(fn: (r) => r[\"_key\"] =~ /:download_total$/)\n  |> filter(fn: (r) => r[\"project\"] =~ /^${project}$/ and r[\"spider\"] =~ /^${spider}$/ and r[\"hostname\"] =~ /^${host}$/)\n  |> group()\n  |> aggregateWindow(every: 1m, fn: sum, createEmpty: true)\n  |> toFloat()\n  |> fill(value: 0.0)\n  |> timedMovingAverage(every: 1m, period: 5m)\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"raw_total_5m\"})",
