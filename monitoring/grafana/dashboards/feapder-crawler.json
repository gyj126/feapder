          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "description": "每条折线表示以该时间点为终点、固定 5 分钟窗口内的滚动比率；图例 Last 为最新 5 分钟窗口值。",
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "9.0.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "alias": "raw_total_5m",
          "query": "SELECT moving_average(\"total\", 5) AS \"total_5m\" FROM (SELECT sum(\"_count\") AS \"total\" FROM \"$measurement\" WHERE \"_classify\"='document' AND \"_key\"=~/:download_total$/ AND \"project\"=~/^$project$/ AND \"spider\"=~/^$spider$/ AND \"hostname\"=~/^$host$/ AND $timeFilter GROUP BY time(1m) fill(0))",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "alias": "raw_success_5m",
          "query": "SELECT moving_average(\"success\", 5) AS \"success_5m\" FROM (SELECT sum(\"_count\") AS \"success\" FROM \"$measurement\" WHERE \"_classify\"='document' AND \"_key\"=~/:download_success$/ AND \"project\"=~/^$project$/ AND \"spider\"=~/^$spider$/ AND \"hostname\"=~/^$host$/ AND $timeFilter GROUP BY time(1m) fill(0))",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "alias": "raw_download_exception_5m",
          "query": "SELECT moving_average(\"download_exception\", 5) AS \"download_exception_5m\" FROM (SELECT sum(\"_count\") AS \"download_exception\" FROM \"$measurement\" WHERE \"_classify\"='document' AND \"_key\"=~/:download_exception$/ AND \"project\"=~/^$project$/ AND \"spider\"=~/^$spider$/ AND \"hostname\"=~/^$host$/ AND $timeFilter GROUP BY time(1m) fill(0))",
          "rawQuery": true,
          "refId": "C",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "alias": "raw_parser_exception_5m",
          "query": "SELECT moving_average(\"parser_exception\", 5) AS \"parser_exception_5m\" FROM (SELECT sum(\"_count\") AS \"parser_exception\" FROM \"$measurement\" WHERE \"_classify\"='document' AND \"_key\"=~/:parser_exception$/ AND \"project\"=~/^$project$/ AND \"spider\"=~/^$spider$/ AND \"hostname\"=~/^$host$/ AND $timeFilter GROUP BY time(1m) fill(0))",
          "rawQuery": true,
          "refId": "D",
          "resultFormat": "time_series"
        }
      ],
      "title": "请求下载趋势",
      "type": "timeseries",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "Time",
            "mode": "outer"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "下载成功率",
            "binary": {
              "left": "raw_success_5m",
              "operator": "/",
              "right": "raw_total_5m"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "下载异常率",
            "binary": {
              "left": "raw_download_exception_5m",
              "operator": "/",
              "right": "raw_total_5m"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "解析异常率",
            "binary": {
              "left": "raw_parser_exception_5m",
              "operator": "/",
              "right": "raw_total_5m"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "raw_total_5m": true,
              "raw_success_5m": true,
              "raw_download_exception_5m": true,
              "raw_parser_exception_5m": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ]
    },
