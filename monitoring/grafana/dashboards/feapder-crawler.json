      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"${measurement}\")\n  |> filter(fn: (r) => r[\"_classify\"] == \"document\")\n  |> filter(fn: (r) => r[\"_field\"] == \"_count\")\n  |> filter(fn: (r) => r[\"_key\"] =~ /:download_total$/ or r[\"_key\"] =~ /:download_success$/)\n  |> filter(fn: (r) => r[\"project\"] =~ /^${project:regex}$/ and r[\"spider\"] =~ /^${spider:regex}$/ and r[\"hostname\"] =~ /^${host:regex}$/)\n  |> map(fn: (r) => ({ r with metric: if r[\"_key\"] =~ /:download_success$/ then \"success\" else \"total\" }))\n  |> group(columns: [\"metric\"])\n  |> sum()\n  |> map(fn: (r) => ({ metric: r.metric, _value: r._value, g: \"1\" }))\n  |> pivot(rowKey: [\"g\"], columnKey: [\"metric\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({ _value: if exists r.success and exists r.total and r.total > 0 then float(v: r.success) / float(v: r.total) else 0.0 }))",
