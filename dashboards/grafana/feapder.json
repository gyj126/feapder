        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "import \"experimental\"\n\nbase = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"feapder_download\" and r.spider =~ /^${spider:regex}$/)\n  |> filter(fn: (r) => r._field == \"count\")\n\nsuccess = base |> filter(fn: (r) => r.status == \"download_success\") |> sum() |> findRecord(fn: (key) => true, idx: 0)\ntotal = base |> filter(fn: (r) => r.status == \"download_total\") |> sum() |> findRecord(fn: (key) => true, idx: 0)\n\nratio = if exists total._value and total._value > 0 then float(v: success._value) / float(v: total._value) else 0.0\n\narray.from(rows: [{_time: now(), _value: ratio}])",
