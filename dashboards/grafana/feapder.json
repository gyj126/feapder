      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"feapder_download\" and r.spider =~ /^${spider:regex}$/)\n  |> filter(fn: (r) => r._field == \"count\" and (r.status == \"download_success\" or r.status == \"download_total\"))\n  |> group(columns: [\"status\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"status\"])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"status\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => exists r.download_total and r.download_total > 0)\n  |> map(fn: (r) => {\n      success_raw = if exists r.download_success then float(v: r.download_success) else 0.0\n      success_capped = if success_raw > float(v: r.download_total) then float(v: r.download_total) else success_raw\n      return {\n          _time: r._time,\n          _value: success_capped / float(v: r.download_total),\n          _field: \"success_rate\",\n      }\n  })",
          "refId": "A"
        }
