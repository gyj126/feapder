        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "import \"array\"\n\nactual = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"feapder_download\" and r.spider =~ /^${spider:regex}$/)\n  |> filter(fn: (r) => r._field == \"count\")\n  |> group()\n  |> reduce(\n      identity: {success: 0, total: 0},\n      fn: (r, accumulator) => ({\n        success: accumulator.success + (if r.status == \"download_success\" then int(v: r._value) else 0),\n        total: accumulator.total + (if r.status == \"download_total\" then int(v: r._value) else 0),\n      }),\n  )\n  |> map(fn: (r) => ({\n      _time: now(),\n      _value: if r.total > 0 then float(v: r.success) / float(v: r.total) else 0.0,\n  }))\n\nplaceholder = array.from(rows: [{_time: now(), _value: 0.0}])\n\nunion(tables: [placeholder, actual])\n  |> sort(columns: [\"_time\"], desc: false)\n  |> last()",
          "refId": "A"
        }
